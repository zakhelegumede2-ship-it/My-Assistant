# Copy this file to .env and fill values. Do NOT commit .env to git.

# Telegram bot token (required)
TELEGRAM_BOT_TOKEN=

# Flask secret key (set to a random string for production)
FLASK_SECRET_KEY=change-me

# Enable Flask debug (True/False)
FLASK_DEBUG=False

# Scheduler timezone (IANA zone, e.g. UTC or Europe/London)
TIMEZONE=UTC
